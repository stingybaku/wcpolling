# Database (PostgreSQL — required)
DATABASE_URL="postgresql://user:password@localhost:5432/wcpolling"

# NextAuth (required)
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (at least one required for login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Email (Resend — required for password reset and notifications)
RESEND_API_KEY=""
RESEND_FROM="noreply@yourdomain.com"

# News feed (optional)
# NEWS_PROVIDER can be "gnews" or "newsapi"
NEWS_PROVIDER=""
GNEWS_API_KEY=""
NEWSAPI_KEY=""
# Automatic newsroom sync (optional). When a provider key is set, the server
# syncs news on a timer. Set NEWS_SYNC_CRON="off" to disable, or override the
# default 60-minute interval with NEWS_SYNC_INTERVAL_MINUTES.
NEWS_SYNC_CRON=""
NEWS_SYNC_INTERVAL_MINUTES="60"

# Match-results auto-pull (optional). When configured, the Match Results admin
# view gets a "Pull results" button that fills scores/shootouts/status onto
# existing fixtures. It never touches stage results or the bracket.
# RESULTS_PROVIDER can be "football-data" or "api-football".
RESULTS_PROVIDER=""

# football-data.org (v4) — FREE tier covers the FIFA World Cup (scores only, no
# card events). Recommended for WC 2026 on a free plan.
FOOTBALL_DATA_KEY=""
RESULTS_COMPETITION="WC"      # football-data competition code

# API-Football (api-sports.io) — richer (card events via the "+ cards" button)
# but the FREE plan has NO access to season 2026; needs a paid plan.
API_FOOTBALL_KEY=""
# Host: direct api-sports (default) or "api-football-v1.p.rapidapi.com" for RapidAPI.
API_FOOTBALL_HOST="v3.football.api-sports.io"
# World Cup league id = 1; season is the kickoff year.
RESULTS_LEAGUE_ID="1"
RESULTS_SEASON="2026"
# Max per-match card-event requests spent in one "+ cards" pull (quota guard).
RESULTS_CARD_BUDGET="40"
