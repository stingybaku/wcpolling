generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  FINISHED
}

enum MatchParticipantSourceType {
  TEAM
  GROUP_POSITION
  MATCH_RESULT
  PLACEHOLDER
  BEST_THIRD
}

enum MatchParticipantOutcome {
  WINNER
  LOSER
}

enum TieBreakerType {
  NUMBER
  TEXT
}

enum PredictionScoreType {
  MATCH
  GROUP_STANDING
  KNOCKOUT
  TIEBREAKER
}

enum TournamentType {
  CLASSIC
  STAGED
}

enum StageType {
  GROUP_QUALIFICATION
  KNOCKOUT
}

enum StageStatus {
  UPCOMING
  OPEN
  CLOSED
  SCORED
}

enum GroupMemberRole {
  MEMBER
  GROUP_ADMIN
}

enum GroupStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BadgeCategory {
  SKILL
  CONSISTENCY
  UNLOCK
  SOCIAL
}

enum MatchRound {
  GROUP
  R32
  R16
  QF
  SF
  FINAL
}

enum MatchResultStatus {
  SCHEDULED
  FINISHED
}

enum TieBreakerMetric {
  TOTAL_GOALS
  FINAL_GOALS
  PENALTY_SHOOTOUTS
  RED_CARDS
}

model User {
  id              String                 @id @default(cuid())
  name            String?
  email           String?                @unique
  passwordHash    String?
  emailVerified   DateTime?
  image           String?
  role            Role                   @default(USER)
  locale          String                 @default("en")
  predictions     Prediction[]
  submissions     PredictionSubmission[]
  memberships     GroupMembership[]
  groupRoomsOwned GroupRoom[]
  accounts        Account[]
  sessions        Session[]
  stagePredictions StagePrediction[]
  stageScores      StageScore[]
  stageTieBreakerAnswers StageTieBreakerAnswer[]
  userBadges       UserBadge[]
  triviaAnswers    TriviaAnswer[]
  triviaAchievements TriviaAchievement[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  description      String?
  teamsPerGroup    Int?
  isActive         Boolean             @default(false)
  submissionDeadline DateTime?
  archivedAt       DateTime?
  type             TournamentType      @default(CLASSIC)
  finalizedAt      DateTime?
  tieBreakerClosedAt DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  groups           TournamentGroup[]
  phases           TournamentPhase[]
  matches          Match[]
  tieBreakers      TieBreakerQuestion[]
  tags             TournamentTag[]
  newsArticles     NewsArticle[]
  sponsoredPlacements SponsoredPlacement[]
  predictions      Prediction[]
  groupRooms       GroupRoom[]
  officialGroupStandings OfficialGroupStanding[]
  officialThirdPlace     OfficialThirdPlaceRanking[]
  stages           TournamentStage[]
  stageTieBreakerAnswers StageTieBreakerAnswer[]
  userBadges       UserBadge[]
  matchResults     MatchResult[]
  triviaQuestions  TriviaQuestion[]
  triviaAchievements TriviaAchievement[]
}

model TournamentTag {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  slug         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, slug])
}

model NewsArticle {
  id                String      @id @default(cuid())
  tournamentId      String
  provider          String
  providerArticleId String?
  title             String
  summary           String?
  url               String      @unique
  sourceName        String?
  imageUrl          String?
  publishedAt       DateTime
  fetchedAt         DateTime    @default(now())
  matchedTags       String?
  tournament        Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, url])
  @@unique([tournamentId, provider, providerArticleId])
  @@index([tournamentId, publishedAt])
}

model SponsoredPlacement {
  id           String     @id @default(cuid())
  tournamentId String
  title        String
  summary      String?
  imageUrl     String?
  targetUrl    String
  ctaLabel     String?
  sponsorName  String?
  badgeLabel   String     @default("Sponsored")
  priority     Int        @default(0)
  isActive     Boolean    @default(true)
  activeFrom   DateTime?
  activeTo     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, isActive, priority])
}

model TournamentGroup {
  id           String                 @id @default(cuid())
  tournamentId String
  name         String
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams        TournamentGroupTeam[]
  matches      Match[]
  homeSourceMatches Match[]           @relation("homeSourceGroup")
  awaySourceMatches Match[]           @relation("awaySourceGroup")
  standings    PredictionGroupStanding[]
  scores       PredictionScore[]
  officialStandings OfficialGroupStanding[]

  @@unique([tournamentId, name])
}

model TournamentPhase {
  id           String       @id @default(cuid())
  tournamentId String
  name         String
  slug         String
  sortOrder    Int          @default(0)
  isKnockout   Boolean      @default(false)
  teamCount    Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@unique([tournamentId, slug])
}

model Team {
  id                String                 @id @default(cuid())
  name              String
  fifaCode          String                 @unique
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  groupMemberships  TournamentGroupTeam[]
  homeMatches       Match[]                @relation("homeMatches")
  awayMatches       Match[]                @relation("awayMatches")
  winningMatches    Match[]                @relation("winningMatches")
  predictedHomeFor      PredictionEntry[]            @relation("predictedHomeTeam")
  predictedAwayFor      PredictionEntry[]            @relation("predictedAwayTeam")
  standings             PredictionGroupStanding[]
  thirdPlaceRankings    PredictionThirdPlaceRanking[]
  officialGroupStandings   OfficialGroupStanding[]
  officialThirdPlace       OfficialThirdPlaceRanking[]
  stageMatchesAsHome       StageMatch[]               @relation("HomeTeam")
  stageMatchesAsAway       StageMatch[]               @relation("AwayTeam")
  stageMatchesAsWinner     StageMatch[]               @relation("WinnerTeam")
  matchResultsAsHome       MatchResult[]              @relation("MatchResultHome")
  matchResultsAsAway       MatchResult[]              @relation("MatchResultAway")
}

model TournamentGroupTeam {
  id        String          @id @default(cuid())
  groupId   String
  teamId    String
  seed      Int?
  createdAt DateTime        @default(now())
  group     TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team      Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([groupId, teamId])
}

model Match {
  id                String            @id @default(cuid())
  tournamentId      String
  phaseId           String
  groupId           String?
  sortOrder         Int               @default(0)
  label             String?
  homeTeamId        String?
  awayTeamId        String?
  homePlaceholder   String?
  awayPlaceholder   String?
  homeSourceType    MatchParticipantSourceType @default(TEAM)
  awaySourceType    MatchParticipantSourceType @default(TEAM)
  homeSourceGroupId String?
  awaySourceGroupId String?
  homeSourcePosition Int?
  awaySourcePosition Int?
  homeSourceMatchId String?
  awaySourceMatchId String?
  homeSourceOutcome MatchParticipantOutcome?
  awaySourceOutcome MatchParticipantOutcome?
  homeSourceThirdRank   Int?
  awaySourceThirdRank   Int?
  homeSourceThirdGroups String?
  awaySourceThirdGroups String?
  scheduledAt       DateTime?
  homeScore         Int?
  awayScore         Int?
  status            MatchStatus       @default(SCHEDULED)
  winnerId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tournament        Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  phase             TournamentPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  group             TournamentGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  homeTeam          Team?             @relation("homeMatches", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam          Team?             @relation("awayMatches", fields: [awayTeamId], references: [id], onDelete: SetNull)
  winner            Team?             @relation("winningMatches", fields: [winnerId], references: [id], onDelete: SetNull)
  homeSourceGroup   TournamentGroup?  @relation("homeSourceGroup", fields: [homeSourceGroupId], references: [id], onDelete: SetNull)
  awaySourceGroup   TournamentGroup?  @relation("awaySourceGroup", fields: [awaySourceGroupId], references: [id], onDelete: SetNull)
  homeSourceMatch   Match?            @relation("homeSourceMatch", fields: [homeSourceMatchId], references: [id], onDelete: SetNull)
  awaySourceMatch   Match?            @relation("awaySourceMatch", fields: [awaySourceMatchId], references: [id], onDelete: SetNull)
  feedsHomeMatches  Match[]           @relation("homeSourceMatch")
  feedsAwayMatches  Match[]           @relation("awaySourceMatch")
  predictionEntries PredictionEntry[]
  predictionScores  PredictionScore[]
}

model TieBreakerQuestion {
  id           String          @id @default(cuid())
  tournamentId String
  prompt       Json
  type         TieBreakerType  @default(NUMBER)
  correctAnswer String?
  acceptedAnswers Json?
  metric       TieBreakerMetric?
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  answers      PredictionTieBreakerAnswer[]
  scores       PredictionScore[]
  stageTieBreakerAnswers StageTieBreakerAnswer[]
}

model GroupRoom {
  id          String                 @id @default(cuid())
  tournamentId String?
  name        String
  description String?
  ownerId     String
  inviteCode  String                 @unique
  status      GroupStatus            @default(APPROVED)
  // Max members allowed in this room. Defaults to the free tier; raised via a
  // one-time Stripe purchase (see GroupUpgrade and lib/group-limits.ts).
  memberCap   Int                    @default(20)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  tournament  Tournament?            @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  owner       User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  submissions PredictionSubmission[]
  stagePredictions StagePrediction[]
  stageScores      StageScore[]
  stageTieBreakerAnswers StageTieBreakerAnswer[]
  userBadges       UserBadge[]
  upgrades         GroupUpgrade[]
}

// Audit + idempotency record for a one-time member-cap upgrade purchased through
// Stripe Checkout. A row is created (PENDING) when the checkout session opens
// and flipped to PAID by the webhook, which then raises GroupRoom.memberCap.
model GroupUpgrade {
  id              String    @id @default(cuid())
  groupId         String
  group           GroupRoom @relation(fields: [groupId], references: [id], onDelete: Cascade)
  stripeSessionId String    @unique
  // Cap this purchase unlocks and the amount charged (USD cents), captured at
  // checkout time so the record stays correct even if the tier table changes.
  memberCap       Int
  amountCents     Int
  status          String    @default("PENDING") // PENDING | PAID
  purchasedById   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([groupId])
}

model GroupMembership {
  id        String          @id @default(cuid())
  userId    String
  groupId   String
  role      GroupMemberRole @default(MEMBER)
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     GroupRoom       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Prediction {
  id               String                      @id @default(cuid())
  userId           String
  tournamentId     String
  name             String
  description      String?
  selected         Boolean                     @default(false)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament       Tournament                  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  entries               PredictionEntry[]
  groupStandings        PredictionGroupStanding[]
  thirdPlaceRankings    PredictionThirdPlaceRanking[]
  tieBreakerAnswers     PredictionTieBreakerAnswer[]
  submissions           PredictionSubmission[]

  @@unique([userId, tournamentId, name])
}

model PredictionThirdPlaceRanking {
  id           String     @id @default(cuid())
  predictionId String
  teamId       String
  rank         Int
  createdAt    DateTime   @default(now())
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([predictionId, teamId])
  @@unique([predictionId, rank])
}

model PredictionEntry {
  id                  String      @id @default(cuid())
  predictionId        String
  matchId             String
  predictedHomeTeamId String?
  predictedAwayTeamId String?
  predictedHomeScore  Int?
  predictedAwayScore  Int?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  prediction          Prediction  @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  match               Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  predictedHomeTeam   Team?       @relation("predictedHomeTeam", fields: [predictedHomeTeamId], references: [id], onDelete: SetNull)
  predictedAwayTeam   Team?       @relation("predictedAwayTeam", fields: [predictedAwayTeamId], references: [id], onDelete: SetNull)

  @@unique([predictionId, matchId])
}

model PredictionGroupStanding {
  id           String          @id @default(cuid())
  predictionId String
  groupId      String
  teamId       String
  position     Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  prediction   Prediction      @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  group        TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([predictionId, groupId, position])
}

model PredictionTieBreakerAnswer {
  id           String            @id @default(cuid())
  predictionId String
  questionId   String
  answer       String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  prediction   Prediction        @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  question     TieBreakerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([predictionId, questionId])
}

model StageTieBreakerAnswer {
  id           String             @id @default(cuid())
  userId       String
  groupId      String
  tournamentId String
  questionId   String
  answer       String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        GroupRoom          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  question     TieBreakerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, tournamentId, questionId])
}

model PredictionSubmission {
  id           String            @id @default(cuid())
  userId       String
  groupId      String
  predictionId String
  submittedAt  DateTime          @default(now())
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        GroupRoom         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  prediction   Prediction        @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  scores       PredictionScore[]

  @@unique([userId, groupId])
}

model PredictionScore {
  id           String               @id @default(cuid())
  submissionId String
  scoreKey     String
  scoreType    PredictionScoreType  @default(MATCH)
  matchId      String?
  groupId      String?
  questionId   String?
  label        String?
  points       Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  submission   PredictionSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  match        Match?               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group        TournamentGroup?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  question     TieBreakerQuestion?  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, scoreKey])
}

model OfficialGroupStanding {
  id           String          @id @default(cuid())
  tournamentId String
  groupId      String
  teamId       String
  position     Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group        TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team         Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, groupId, position])
  @@unique([tournamentId, groupId, teamId])
}

model OfficialThirdPlaceRanking {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  rank         Int
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@unique([tournamentId, rank])
}

// ─── Staged Tournament Models ─────────────────────────────────────────────────

model TournamentStage {
  id            String       @id @default(cuid())
  tournamentId  String
  tournament    Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  type          StageType
  status        StageStatus  @default(UPCOMING)
  name          String
  roundLabel    String?
  order         Int

  opensAt       DateTime
  closesAt      DateTime

  stagePredictions        StagePrediction[]
  stageScores             StageScore[]
  stageMatches            StageMatch[]
  qualificationResult     StageQualificationResult?
  groupResult             StageGroupResult?
  userBadges              UserBadge[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tournamentId, order])
}

model StageMatch {
  id          String          @id @default(cuid())
  stageId     String
  stage       TournamentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  matchNumber String
  homeTeamId  String
  homeTeam    Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String
  awayTeam    Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  matchDate   DateTime?
  winnerId    String?
  winner      Team?           @relation("WinnerTeam", fields: [winnerId], references: [id])
  matchResult MatchResult?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([stageId, matchNumber])
}

model StageQualificationResult {
  id         String          @id @default(cuid())
  stageId    String          @unique
  stage      TournamentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  qualifiers Json
  createdAt  DateTime        @default(now())
}

model StageGroupResult {
  id          String          @id @default(cuid())
  stageId     String          @unique
  stage       TournamentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  standings   Json            // { [groupId]: string[] } ordered team IDs per group
  thirdPlace  Json            // string[] - all 12 thirds in ranked order (top 8 advance)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StagePrediction {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId   String
  stage     TournamentStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  groupId   String
  group     GroupRoom        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  qualificationPicks  Json?
  matchPicks          Json?

  submittedAt       DateTime?
  unlockedAt        DateTime?
  unlockCount       Int       @default(0)
  lockedOutMatchIds Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, stageId, groupId])
}

model StageScore {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId  String
  stage    TournamentStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  groupId  String
  group    GroupRoom        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  points        Int   @default(0)
  correctPicks  Int   @default(0)
  breakdown     Json

  createdAt  DateTime  @default(now())

  @@unique([userId, stageId, groupId])
}

model EmailLog {
  id      String   @id @default(cuid())
  userId  String
  type    String
  refId   String
  sentAt  DateTime @default(now())

  @@unique([userId, type, refId])
}

model Badge {
  id        String        @id @default(cuid())
  slug      String        @unique // i18n key + criteria id, e.g. "clean_sweep"
  category  BadgeCategory
  icon      String? // icon ref / emoji, never display text
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  // Context — badges are per-group, and either per-stage or per-tournament.
  groupId      String
  group        GroupRoom        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  stageId      String?
  stage        TournamentStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  // Idempotency discriminator: stageId for stage badges, "tournament" for tournament-level.
  // A plain string avoids Postgres treating NULL stageIds as distinct in the unique index.
  contextKey String

  // Only non-derivable dynamic values (e.g. streak length). Names resolve from relations.
  params Json?

  awardedAt DateTime @default(now())

  @@unique([userId, badgeId, groupId, contextKey])
  @@index([userId])
  @@index([groupId, tournamentId])
}

// Admin-tracked real-world result + team-level stats for each World Cup match.
// Independent of the prediction machinery (StageMatch winner / scoring); used for
// record-keeping, the public match center, and auto-resolving tie-breakers.
model MatchResult {
  id           String            @id @default(cuid())
  tournamentId String
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  round     MatchRound
  groupName String? // group letter for GROUP-round matches
  matchNumber Int   // ordering within the round (and group, for group stage)

  homeTeamId String
  homeTeam   Team   @relation("MatchResultHome", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeamId String
  awayTeam   Team   @relation("MatchResultAway", fields: [awayTeamId], references: [id], onDelete: Cascade)

  // Knockout rows are synced from the bracket; this links back without coupling scoring.
  stageMatchId String?     @unique
  stageMatch   StageMatch? @relation(fields: [stageMatchId], references: [id], onDelete: SetNull)

  kickoffAt DateTime?
  venue     String?
  status    MatchResultStatus @default(SCHEDULED)

  homeScore Int?
  awayScore Int?
  homeYellow Int @default(0)
  awayYellow Int @default(0)
  homeRed    Int @default(0)
  awayRed    Int @default(0)

  penaltyShootout Boolean @default(false)
  homePenalties   Int?
  awayPenalties   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, round, groupName, matchNumber])
  @@index([tournamentId])
}

// ─── Daily Trivia ──────────────────────────────────────────────────────────────
// A standalone engagement feature, fully decoupled from groups and prediction
// scoring. One admin-authored multiple-choice question per tournament per day;
// points and streaks are derived from TriviaAnswer rows (no denormalized
// counters). A 5-day correct streak grants the global "Triviador" achievement.

model TriviaQuestion {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  // The day this question is live. Date-only (UTC) so "one per day" is a clean
  // unique constraint and "today's question" is a simple equality match.
  publishDate  DateTime   @db.Date
  prompt       Json       // { en, es }
  options      Json       // [{ key, label: { en, es } }, ...]
  correctKey   String
  points       Int        @default(2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  answers      TriviaAnswer[]

  @@unique([tournamentId, publishDate])
  @@index([tournamentId])
}

model TriviaAnswer {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerKey  String
  isCorrect  Boolean
  answeredAt DateTime       @default(now())

  // One shot per user per day — no retries until correct.
  @@unique([userId, questionId])
  @@index([userId])
}

model TriviaAchievement {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  slug         String     @default("triviador")
  // The streak length that earned it, for display (e.g. "5-day streak").
  streakLength Int
  awardedAt    DateTime   @default(now())

  @@unique([userId, tournamentId, slug])
  @@index([userId])
}
